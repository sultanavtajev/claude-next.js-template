{
  "$schema": "https://json.schemastore.org/mcp-servers.json",
  "_comment": "MCP-servere for dette prosjektet. {{PLACEHOLDERS}} fylles inn i oppstart-steg 01. Env-variabler som ${TOKEN_NAME} må finnes i brukerens shell eller .env.local. VIKTIG: stdio-entries bruker cmd /c npx ... som Windows-kompatibel wrapper — ikke-Windows-brukere kan bytte til direkte npx (fjern 'cmd' + '/c' fra command/args).",
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com"
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref={{SUPABASE_PROJECT_REF}}",
      "headers": {
        "Authorization": "Bearer ${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "resend": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "resend-mcp"],
      "env": {
        "RESEND_API_KEY": "${RESEND_API_KEY}"
      }
    },
    "playwright": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@playwright/mcp@latest"]
    },
    "next-devtools": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "next-devtools-mcp@latest"]
    },
    "context7": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@upstash/context7-mcp"],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "shadcn": {
      "command": "cmd",
      "args": ["/c", "npx", "shadcn@latest", "mcp"]
    },
    "chrome-devtools": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "chrome-devtools-mcp@latest"]
    }
  }
}
